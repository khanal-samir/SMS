# ======================
# Version control
# ======================
.git
.gitignore
.github

# ======================
# Dependencies (rebuilt inside the container)
# ======================
**/node_modules

# ======================
# Build artifacts (rebuilt inside the container)
# ======================
**/dist
**/.next
**/.turbo

# ======================
# Environment / secrets (passed at runtime, never baked in)
# ======================
.env
.env.*
**/.env
**/.env.*

# ======================
# Docker files (no need to copy themselves into the image)
# ======================
Dockerfile
Dockerfile.*
docker-compose*.yml
docker-compose*.yaml
.dockerignore

# ======================
# IDE / editor configs
# ======================
.vscode
.idea
*.swp
*.swo
*~

# ======================
# Debug logs
# ======================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ======================
# Test & coverage output
# ======================
**/coverage
**/.nyc_output
**/jest.config.ts
**/__tests__
**/*.spec.ts
**/*.test.ts
**/*.spec.js
**/*.test.js

# ======================
# Documentation & metadata (not needed at runtime)
# ======================
README.md
README
LICENSE
CHANGELOG.md
CONTRIBUTING.md
docs

# ======================
# Misc
# ======================
.opencode
.prettierrc
.prettierignore
.eslintrc*
.eslintignore
*.md
